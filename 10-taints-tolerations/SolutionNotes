# Solution: Q10 — Taints & Tolerations
#
# Step 1: Taint the node
kubectl taint nodes node01 PERMISSION=granted:NoSchedule

# Step 2: Create pod with toleration
cat <<'EOF' | kubectl apply -f -
apiVersion: v1
kind: Pod
metadata:
  name: nginx
spec:
  containers:
  - name: nginx
    image: nginx
  tolerations:
  - key: PERMISSION
    operator: Equal
    value: granted
    effect: NoSchedule
EOF

# Step 3: Verify
kubectl get pods -o wide  # nginx should be Running on node01
