#!/bin/bash
set -euo pipefail

echo "[INFO] Creating namespace priority..."
kubectl create namespace priority --dry-run=client -o yaml | kubectl apply -f -

echo "[INFO] Creating PriorityClass user-critical (value 1000)..."
kubectl apply -f - <<'EOF'
apiVersion: scheduling.k8s.io/v1
kind: PriorityClass
metadata:
  name: user-critical
value: 1000
globalDefault: false
description: "Highest user-defined priority class"
EOF

echo "[INFO] Creating deployment busybox-logger..."
kubectl apply -f - <<'EOF'
apiVersion: apps/v1
kind: Deployment
metadata:
  name: busybox-logger
  namespace: priority
spec:
  replicas: 1
  selector:
    matchLabels:
      app: busybox-logger
  template:
    metadata:
      labels:
        app: busybox-logger
    spec:
      containers:
      - name: busybox
        image: busybox
        command: ["sh", "-c", "while true; do echo 'logging...'; sleep 5; done"]
EOF

echo "[DONE] Lab setup complete — busybox-logger in priority namespace"
echo "       Create PriorityClass high-priority (value=999), patch deployment"
