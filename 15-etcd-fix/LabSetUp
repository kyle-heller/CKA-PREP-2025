#!/bin/bash
set -euo pipefail

echo "[INFO] Backing up kube-apiserver manifest..."
sudo cp /etc/kubernetes/manifests/kube-apiserver.yaml /root/kube-apiserver.yaml.bak

echo "[INFO] Simulating etcd misconfiguration — changing port 2379 to 2380..."
sudo sed -i 's/:2379/:2380/g' /etc/kubernetes/manifests/kube-apiserver.yaml

echo "[INFO] Waiting for API server to fail..."
sleep 5

echo "[WARN] API server is now broken — kube-apiserver is pointing to etcd peer port 2380"
kubectl get nodes 2>/dev/null || echo "[EXPECTED] kubectl failing — API server is down"

echo "[DONE] Lab setup complete — fix etcd port in /etc/kubernetes/manifests/kube-apiserver.yaml"
