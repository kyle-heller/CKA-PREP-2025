# Solution: Q04 — Resource Allocation
#
# Step 1: Scale down
kubectl scale deployment wordpress -n resources --replicas=0

# Step 2: Edit deployment — set same resources on all init + main containers
kubectl edit deployment wordpress -n resources
# In spec.template.spec.containers[] and spec.template.spec.initContainers[] set:
# resources:
#   requests:
#     cpu: "300m"
#     memory: "600Mi"
#   limits:
#     cpu: "400m"
#     memory: "700Mi"

# Step 3: Scale back up
kubectl scale deployment wordpress -n resources --replicas=3
kubectl rollout status deployment wordpress -n resources
kubectl get pods -n resources -l app=wordpress
